{
  "main entry point": {
    "prefix": "main-snippet",
    "description": "main entry point snippet",
    "body": [
      "def main() -> None:",
      "    ${1:...}",
      "",
      "",
      "if __name__ == '__main__':",
      "    main()",
      ""
    ]
  },
  "function": {
    "prefix": "def-snippet",
    "description": "function snippet",
    "body": [
      "def ${1:new_function}($2) -> ${3:None}:",
      "    ${4:raise NotImplementedError('$1() was not implemented.')}"
    ]
  },
  "debug": {
    "prefix": "debug-snippet",
    "description": "debug snippet",
    "body": ["print(f'${1:name} = {${2:var}}')", "$0"]
  },
  "try/except": {
    "prefix": "try-except-snippet",
    "description": "try/except block snippet",
    "body": [
      "try:",
      "    ${1:...}",
      "except Exception as e:",
      "    print(f'{type(e).__name__}: {e}')",
      "$0"
    ]
  }
}
